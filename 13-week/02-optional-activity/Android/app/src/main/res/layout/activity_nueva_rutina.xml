<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nueva Rutina"
            android:textColor="#E94560"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Completa los datos de tu rutina"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre de la rutina"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etNombreRutina"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej: Rutina Pecho y Tríceps"
            android:textColorHint="#555555"
            android:textColor="#FFFFFF"
            android:background="#1E1E1E"
            android:padding="12dp"
            android:inputType="text"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Día de la semana"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spinnerDia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1E1E1E"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Número de ejercicios"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etNumEjercicios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej: 4"
            android:textColorHint="#555555"
            android:textColor="#FFFFFF"
            android:background="#1E1E1E"
            android:padding="12dp"
            android:inputType="number"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/tvError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Error al guardar. Verifica tu conexión."
            android:textColor="#E94560"
            android:textSize="13sp"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnGuardarRutina"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Guardar Rutina"
            android:backgroundTint="#E94560"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:padding="16dp"/>

    </LinearLayout>
</ScrollView>